<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://kit.fontawesome.com/64d58efce2.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="./css/main.css" />
    <script src="//ajax.googleapis.com/ajax/libs/jquery/2.1.1/jquery.min.js">
    </script>

    <title>Sign in & Sign up Form</title>
</head>

<body>
    <%- include("message") %>
            <div class="containers">
                <div class="forms-container">

                    <!-- Logueo Form-->
                    <div class="signin-signup">
                        <form class="sign-in-form" action="/user/signin" method="post">
                            <h2 class="title">Sign in</h2>
                            <div class="input-field">
                                <i class="fas fa-user"></i>
                                <input name="email" id="loginemail" type="email" placeholder="Correo empresarial" />
                            </div>
                            <div class="input-field">
                                <i class="fas fa-lock"></i>
                                <input name="password" id="loginpass" type="password" placeholder="Contraseña" />
                            </div>
                            <div class="input-field">
                                <i class="fas fa-id-card"></i>
                                <input name="ced" id="loginced" type="number" placeholder="Cedula" value="" required />
                            </div>
                            <input type="submit" value="Login" class="btn solid" />
                        </form>

                        <!-- Registro Form-->
                        <form class="sign-up-form" action="/user/signup" method="post" enctype="multipart/form-data">
                            <h2 class="title">Sign up</h2>
                            <div class="input-field">
                                <i class="fas fa-user"></i>
                                <input name="name" id="registuser" type="text" placeholder="Nombre completo" value="" required />
                            </div>
                            <div class="input-field">
                                <i class="fas fa-id-card"></i>
                                <input name="ced" id="registced" type="text" placeholder="Cedula" value="" required />
                            </div>
                            <div class="input-field">
                                <i class="fas fa-envelope"></i>
                                <input name="email" id="registemail" type="text" placeholder="Correo empresarial" value="" required />
                            </div>
                            <div class="input-field">
                                <i class="fas fa-lock"></i>
                                <input name="password" id="registpass" type="password" placeholder="Contraseña" value="" required />
                            </div>
                            <div class="input-field">
                                <i class="fas fa-phone"></i>
                                <input name="phone" id="registphone" type="text" placeholder="Telefono" value="" />
                            </div>
                            <div class="input-field">
                                <i class="fas fa-image-user"></i>
                                <input name="image" id="image" type="file" accept="image/png, image/gif, image/jpeg" />
                            </div>
                            <input type="submit" class="btn" value="Sign up" id="Registerbtn" />
                        </form>
                    </div>
                </div>

                <div class="panels-container">
                    <div class="panel left-panel">
                        <div class="content">
                            <h3>¿No tienes cuenta registrada?</h3>
                            <p>
                                Registrate con nosotros solo dando a un bóton!
                            </p>
                            <button class="btn transparent" id="sign-up-btn">
            Registrarse
          </button>
                        </div>
                        <img src="/img/log.svg" class="image" alt="" />
                    </div>
                    <div class="panel right-panel">
                        <div class="content">
                            <h3>¿Ya estas registrado como uno de nosotros?</h3>
                            <p>
                                Inicia sesión en tu cuenta personal con solo un bóton.
                            </p>
                            <button class="btn transparent" id="sign-in-btn">
            Iniciar sesion
          </button>
                        </div>
                        <img src="/img/register.svg" class="image" alt="" />
                    </div>
                </div>
            </div>

            <!--<script src="js/registfrom.js"></script>-->

            <script src="/js/login.js"></script>
</body>

</html>